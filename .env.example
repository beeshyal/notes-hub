# --- NextAuth (viewer Google sign-in) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# --- Google Drive (storage for uploaded notes - your own admin account) ---
DRIVE_CLIENT_ID=your-drive-oauth-client-id.apps.googleusercontent.com
DRIVE_CLIENT_SECRET=your-drive-oauth-client-secret
DRIVE_REFRESH_TOKEN=your-drive-refresh-token
DRIVE_FOLDER_ID=the-google-drive-folder-id-that-holds-notes

# --- Vercel KV (document metadata store) ---
# Auto-filled when you attach a KV database to your Vercel project.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Admin ---
# Comma separated emails allowed to upload/manage notes
ADMIN_EMAILS=you@gmail.com

# --- Ad unlock ---
# Secret used to sign short-lived unlock tokens for the "watch ad to download" flow
UNLOCK_SECRET=replace-with-another-random-string
AD_WAIT_SECONDS=15
NEXT_PUBLIC_AD_WAIT_SECONDS=15

# --- AdSense ---
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT=xxxxxxxxxx

# --- Contact (shown on the About page) ---
NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
